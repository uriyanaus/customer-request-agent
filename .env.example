# Copy to .env and fill in to use the real LLM classifier.
# Optional — without a key the agent runs in deterministic mock mode.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides (defaults shown):
# AGENT_LLM=auto                  # auto | anthropic | mock (auto -> Claude when a key is set)
# AGENT_MODEL=claude-haiku-4-5
